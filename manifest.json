{
  "manifest_version": 3,
  "name": "Easy Apply — Autofill de Postulaciones con IA",
  "version": "0.3.0",
  "description": "Rellena postulaciones de trabajo: datos básicos en automático y respuestas a preguntas únicas con IA. Nunca envía nada solo.",
  "key": "",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "options_page": "src/options/options.html",
  "side_panel": {
    "default_path": "src/sidepanel/panel.html"
  },
  "permissions": ["storage", "unlimitedStorage", "alarms", "sidePanel", "nativeMessaging"],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "https://raw.githubusercontent.com/*",
    "https://api.github.com/*"
  ],
  "optional_host_permissions": ["*://*/*"],
  "content_scripts": [
    {
      "matches": [
        "https://boards.greenhouse.io/*",
        "https://boards.eu.greenhouse.io/*",
        "https://job-boards.greenhouse.io/*",
        "https://job-boards.eu.greenhouse.io/*",
        "https://jobs.lever.co/*",
        "https://jobs.eu.lever.co/*"
      ],
      "js": ["src/content/ats.js"],
      "css": ["src/content/ats.css"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["src/content/linkedin.js"],
      "run_at": "document_idle"
    }
  ]
}
